{
  "name": "3dmotion-vite-lvrr3j",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:roundtrip": "node scripts/playwright/desktop-roundtrip.mjs",
    "test:electrostatic-lab-interactions": "node scripts/playwright/electrostatic-lab-advanced-interactions.mjs",
    "test:visual-smoke": "node scripts/playwright/desktop-visual-regression.mjs",
    "test:visual-smoke:update": "node scripts/playwright/desktop-visual-regression.mjs --update-baseline",
    "test:e2e": "npm run test:roundtrip && npm run test:electrostatic-lab-interactions && npm run test:touch && npm run test:visual-smoke",
    "test:e2e:ci": "BASE_URL=${BASE_URL:-http://127.0.0.1:4180} npm run test:e2e",
    "test:touch": "node scripts/playwright/touch-regression.mjs",
    "verify:ci": "npm run lint && npm run check:scene-shell-length && npm test && npm run build && npm run check:homepage-preload && npm run check:bundle-budget && npm run check:clean-build && npm run check:route-load-budget",
    "verify:full": "npm run verify:ci && npm run test:e2e",
    "scaffold:scene": "node scripts/scaffold/new-scene.mjs",
    "check:homepage-preload": "node scripts/perf/assert-homepage-preload.mjs",
    "check:bundle-budget": "node scripts/perf/assert-bundle-budgets.mjs",
    "check:route-load-budget": "node scripts/perf/assert-route-load-budget.mjs",
    "check:clean-build": "node scripts/ci/check-clean-build.mjs",
    "check:scene-shell-length": "node scripts/ci/check-scene-shell-length.mjs",
    "test:perf": "npm run build && npm run check:homepage-preload && npm run check:bundle-budget",
    "test:1080p-presentation": "node scripts/playwright/1080p-presentation-regression.mjs"
  },
  "dependencies": {
    "@react-three/drei": "^10.7.7",
    "@react-three/fiber": "^9.5.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "three": "0.183.1",
    "three-stdlib": "^2.36.1",
    "zustand": "^5.0.11"
  },
  "overrides": {
    "stats-gl": {
      "three": "0.183.1"
    }
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^24.10.14",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@types/three": "0.183.1",
    "@vitejs/plugin-react": "^5.1.1",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "globals": "^16.5.0",
    "jsdom": "^28.1.0",
    "pixelmatch": "^7.1.0",
    "playwright": "^1.58.2",
    "pngjs": "^7.0.0",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.48.0",
    "vite": "^7.3.1",
    "vitest": "^4.0.18"
  }
}
